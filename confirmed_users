#All users are unconfirmed, and none are confirmed
unconfirmed_users = ['alice', 'brian', 'candace']
confirmed_users = []

#One by one verify each user
#Move them to the confirmed list
while unconfirmed_users:
	current_user = unconfirmed_users.pop()
	print(f"Verifying user: {current_user.title()}")
	confirmed_users.append(current_user)

#Display all confirmed users
print(f"The following users have been confirmed:")
for confirmed_users in confirmed_users:
	print(confirmed_users.title())