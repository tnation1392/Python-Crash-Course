#Creating a list of guests
guests = ['Charles Darwin', 'Marcus Aurelius', 'Abraham Lincoln', 'Tom Brady', 'Larry Bird']

print(f'Im inviting {guests[0]}, {guests[1]}, {guests[2]}, {guests[3]}, and {guests[4]} to my party.')

#Creating a pop. value
cantmakeit = guests.pop(2)

print(f'I just found out that {cantmakeit} isnt coming')

#printing the list without the cantmakeit value
print(f'So now Im inviting {guests[0]}, {guests[1]}, {guests[2]}, and {guests[3]} to my party.')

